
# 默认服务商（兜底用）
LLM_DEFAULT_PROVIDER=aliyun
# aiposit.gagalin.delick 常数 （建议修改之前联系算法侧）
AIPOSIT_GAGALIN_DELICK_CONSTANT=0

# ========== 阿里云配置 ==========
ALIYUN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

ALIYUN_API_KEY=sk-614f2e32ce44483892c6fd2ce494d4ac
ALIYUN_API_KEY_2=sk-fbe5ffcc328442b699eab29ebb28e4d8
ALIYUN_API_KEY_3=sk-81dbc3bac93a4aca9cb5e94627e91fd4

# 默认模型
ALIYUN_DEFAULT_MODEL=qwen-plus

# 阿里云模型映射（仅保留测试通过的模型）
ALIYUN_MODELS={"qwen-flash":"qwen-flash","qwen-turbo":"qwen-turbo","qwen-plus":"qwen-plus","qwen-long":"qwen-long","qwen-vl-plus":"qwen-vl-plus","qwen-vl-max-latest":"qwen-vl-max-latest","qwen2.5-7b-instruct":"qwen2.5-7b-instruct","qwen2.5-14b-instruct":"qwen2.5-14b-instruct","qwen-coder-plus-latest":"qwen-coder-plus-latest","qwen-coder-turbo-0919":"qwen-coder-turbo-0919","qwen-math-plus":"qwen-math-plus","qwen-math-turbo":"qwen-math-turbo"}

# 阿里云备用模型列表（仅保留可用的）
ALIYUN_FALLBACK_MODELS=["qwen-flash","qwen-plus","qwen-turbo"]

