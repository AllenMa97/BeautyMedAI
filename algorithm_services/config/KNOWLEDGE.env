
# ========== 知识库配置 ==========
# 
# 本配置文件用于设置知识库服务的默认参数
# 
# 可用的数据库类型：
# - full: 完整产品库（包含所有产品）
# - group: 集团库（按集团分类的产品库）
# - brand: 品牌库（按品牌分类的产品库）
#
# 当前可用的集团ID：
# - yuanxiang: 远想集团（伊肤泉、丽芙莎、OMICY、瑞恩诗）
# - loreal: 欧莱雅集团（兰蔻、雅诗兰黛、科颜氏）
# - pg: 宝洁集团（玉兰油、SK-II）
# - estee_lauder_group: 雅诗兰黛集团（雅诗兰黛、倩碧、海蓝之谜）
# - shiseido: 资生堂集团（资生堂、CPB肌肤之钥、IPSA茵芙莎）
# - lvmh: LVMH集团（迪奥、纪梵希、娇兰）
# - chanel: 香奈儿集团（香奈儿）
# - unilever: 联合利华集团（凡士林、多芬）
# - amorepacific: 爱茉莉太平洋集团（雪花秀、兰芝）
# - lg_household: LG生活健康集团（后、苏秘37°）
#
# 当前可用的品牌ID：
# 远想集团：
# - yifuquan: 伊肤泉
# - lifusha: 丽芙莎
# - omicy: OMICY
# - ruienshi: 瑞恩诗
#
# 欧莱雅集团：
# - lancome: 兰蔻
# - estee_lauder: 雅诗兰黛
# - kiehls: 科颜氏
#
# 宝洁集团：
# - olay: 玉兰油
# - skii: SK-II
#
# 雅诗兰黛集团：
# - estee_lauder_el: 雅诗兰黛
# - clinique: 倩碧
# - la_mer: 海蓝之谜
#
# 资生堂集团：
# - shiseido_brand: 资生堂
# - cpb: CPB肌肤之钥
# - ipsa: IPSA茵芙莎
#
# LVMH集团：
# - dior: 迪奥
# - givenchy: 纪梵希
# - guerlain: 娇兰
#
# 香奈儿集团：
# - chanel_brand: 香奈儿
#
# 联合利华集团：
# - vaseline: 凡士林
# - dove: 多芬
#
# 爱茉莉太平洋集团：
# - sulwhasoo: 雪花秀
# - laneige: 兰芝
#
# LG生活健康集团：
# - whoo: 后
# - sum37: 苏秘37°
#

# 默认数据库类型 (full/group/brand)
KNOWLEDGE_DEFAULT_DB_TYPE=group

# 默认数据库ID (当DB_TYPE为group或brand时需要指定)
# 示例：
# - 使用远想集团库：KNOWLEDGE_DEFAULT_DB_ID=yuanxiang
# - 使用伊肤泉品牌库：KNOWLEDGE_DEFAULT_DB_ID=yifuquan
# - 使用完整库：KNOWLEDGE_DEFAULT_DB_TYPE=full (此时DB_ID不需要设置)
KNOWLEDGE_DEFAULT_DB_ID=yuanxiang

# 默认检索模式 (vector/keyword/hybrid)
# - vector: 向量检索（语义相似度）
# - keyword: 关键词检索（精确匹配）
# - hybrid: 混合检索（结合向量和关键词，推荐）
KNOWLEDGE_DEFAULT_SEARCH_MODE=hybrid

# 默认检索数量
# 建议范围：5-20
KNOWLEDGE_DEFAULT_TOP_K=10

# 默认相似度阈值
# 建议范围：0.1-0.5，值越小返回结果越多
KNOWLEDGE_DEFAULT_THRESHOLD=0.3

# 默认检索类型 (all/products/entries)
# - all: 检索产品和知识条目
# - products: 只检索产品
# - entries: 只检索知识条目
KNOWLEDGE_DEFAULT_SEARCH_TYPE=all
