# ==============================================================================
# 定时任务与缓存时间间隔配置
# ==============================================================================

# ========== API Key 检测配置 ==========
# API Key 检测间隔（秒），默认4小时（14400秒）
# 24小时内检测 24 * 3600 / 14400 = 6 次
API_KEY_CHECK_INTERVAL=14400

# ========== 内容更新配置 ==========
# 热点/时尚/外部知识更新间隔（秒），默认4小时（14400秒）
CONTENT_UPDATE_INTERVAL=14400

# ========== 模拟用户生成配置 ==========
# 模拟用户生成检查间隔（秒），默认30分钟（1800秒）
SIMULATION_CHECK_INTERVAL=1800

# ========== 意图缓存配置 ==========
# 意图缓存 TTL（秒），默认1小时（3600秒）
INTENT_CACHE_TTL=3600

# ========== 热搜缓存配置 ==========
# 热搜缓存 TTL（秒），默认30分钟（1800秒）
TRENDING_CACHE_TTL=1800

# ========== 对话摘要配置 ==========
# 对话摘要时间阈值（秒），5分钟内不重复摘要，默认300秒
DIALOG_SUMMARY_TIME_THRESHOLD=300

# ========== 用户画像更新配置 ==========
# 用户画像更新时间阈值（秒），默认5分钟（300秒）
USER_PROFILE_UPDATE_INTERVAL=300

# ========== 用户记忆挖掘配置 ==========
# 用户记忆挖掘间隔（秒），默认2小时（7200秒）
# 实际执行时间：仅在凌晨1-5点且系统低负载时执行
MEMORY_MINING_INTERVAL=7200
